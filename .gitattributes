# Normalize text files to LF in the repository
* text=auto eol=lf

# Keep Windows batch scripts with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text eol=lf
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary